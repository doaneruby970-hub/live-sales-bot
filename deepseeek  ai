import os
from openai import OpenAI

# 配置 DeepSeek 客户端
client = OpenAI(
    api_key=os.getenv("DEEPSEEK_API_KEY", ""),  # 从环境变量读取
    base_url="https://api.deepseek.com"
)

def get_watch_sales_pitch(watch_info, audience_mood="excited", interaction_type="introduction"):
    """
    watch_info: 手表参数（字典）
    audience_mood: 直播间氛围 (calm, excited, skeptical)
    interaction_type: 交互类型 (introduction, objection_handling, closing)
    """

    # 构建系统提示词 (System Prompt) - 这是智能体的灵魂
    system_prompt = f"""
    你是一位拥有10年经验的高端名表直播销售专家。你的风格是：专业、优雅、富有激情且极具说服力。

    请遵循以下原则：
    1. **专业背书**：准确使用术语（如：蓝宝石镜面、导柱轮机芯、316L精钢、日内瓦纹打磨）。
    2. **场景化描述**：不要只念参数，要描绘佩戴场景（商务谈判、休闲潜水）。
    3. **情绪价值**：强调手表的身份象征和传承价值。
    4. **促单技巧**：适当制造紧迫感（库存、限时福利）。

    当前直播间氛围：{audience_mood}
    """

    # 构建用户输入
    user_content = f"""
    请针对这款手表生成一段话术。
    手表信息：{watch_info}
    当前环节：{interaction_type}
    """

    response = client.chat.completions.create(
        model="deepseek-chat",
        messages=[
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_content},
        ],
        temperature=0.7, # 稍微高一点的温度让话术更自然、有灵性
        stream=False
    )

    return response.choices[0].message.content

# --- 测试调用 ---
watch_data = {
    "brand": "欧米茄 (Omega)",
    "model": "海马系列 300米潜水表",
    "feature": "8800同轴至臻天文台机芯，黑色陶瓷表圈",
    "price": "4xxxx",
    "pain_point": "粉丝觉得有点贵"
}

print(get_watch_sales_pitch(watch_data, "skeptical", "objection_handling"))